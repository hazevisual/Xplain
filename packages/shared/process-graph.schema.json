{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xplain.local/schemas/process-graph.schema.json",
  "title": "ProcessGraph",
  "type": "object",
  "required": ["processId", "version", "nodes", "edges"],
  "properties": {
    "processId": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "nodes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/edge"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "sourceRefs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "required": ["id", "type", "title", "level"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": ["stage", "subprocess", "component", "data", "actor"]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "level": {
          "type": "string",
          "enum": ["L1", "L2", "L3"]
        },
        "meta": {
          "type": "object",
          "additionalProperties": true,
          "default": {}
        }
      },
      "additionalProperties": false
    },
    "edge": {
      "type": "object",
      "required": ["id", "from", "to", "kind"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "from": {
          "type": "string",
          "minLength": 1
        },
        "to": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": ["flow", "depends_on", "uses", "produces"]
        },
        "meta": {
          "type": "object",
          "additionalProperties": true,
          "default": {}
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
